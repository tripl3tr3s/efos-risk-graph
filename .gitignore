# Dependencies
node_modules/
.pnpm-store/

# Build output
# NOTE: dist/ is intentionally committed. This package is consumed as a git
# dependency (no npm publish); shipping prebuilt dist means consumers never run
# a build script on install, so no pnpm allowBuilds gate or nested-workspace
# breakage across pnpm 9/10/11. Rebuild with `pnpm build` before tagging.
build/
*.tsbuildinfo

# Test / coverage
coverage/
.nyc_output/
*.lcov

# Caches
.cache/
.vitest/
.eslintcache

# Environment / secrets
.env
.env.*
!.env.example

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.swp

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Packaged tarballs
*.tgz
